# Copy this to .env and fill in your values
# DO NOT commit .env to git

# Your wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Get from Alchemy or Infura - free tier works fine
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Get from etherscan.io - for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_key_here

# Chainlink VRF Sepolia values (these are already filled with correct Sepolia addresses)
VRF_COORDINATOR=0x9DdfaCa8183c41ad55329BdeeD9F6A8d53168B1
VRF_SUBSCRIPTION_ID=your_subscription_id_here
VRF_KEY_HASH=0x787d74caea10b2b357790d5b5247c2f63d1d91572a9846f780606e4d953677ae
